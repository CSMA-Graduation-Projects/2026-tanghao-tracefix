APP_NAME=cfix-server
APP_ENV=dev
APP_DEBUG=true
API_V1_STR=/api/v1
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://127.0.0.1:5173,http://localhost:5173

MYSQL_HOST=sh-cynosdbmysql-grp-ka5o4h5k.sql.tencentcdb.com
MYSQL_PORT=29496
MYSQL_USER=admin
MYSQL_PASSWORD=Tanghao52531314
MYSQL_DB=cfix_db

JWT_SECRET=CFIX@TH5253
JWT_ALG=HS256
JWT_EXPIRE_MIN=120

# ===== LLM 配置 =====
# 可选：qwen / openai / deepseek
LLM_PROVIDER=qwen

# 开关：true 表示启用真实模型；false 表示继续走本地占位逻辑
LLM_ENABLE=true

# 推荐：qwen3-coder-next
LLM_MODEL=
# 北京地域 OpenAI 兼容地址
LLM_BASE_URL=
# 你的 API Key
LLM_API_KEY=
# 超时时间（秒）
LLM_TIMEOUT=1800
# 生成温度
LLM_TEMPERATURE=0.2
# 最大输出 token
LLM_MAX_TOKENS=4096
# true 时，真实模型失败会直接抛错，避免误以为跑通了真链路
LLM_STRICT=true
# 真实模型调用失败后的自动重试次数
LLM_RETRY_COUNT=2
# 简单线性退避秒数
LLM_RETRY_BACKOFF_SEC=1.0
# 是否清理 qwen 常见的 <think>...</think>
LLM_STRIP_THINK=true

# ===== 沙箱执行配置 =====
# safe_exec / docker
SANDBOX_BACKEND=docker

SANDBOX_TIMEOUT_SEC=30
SANDBOX_IMAGE=cfix-python-sandbox:latest
SANDBOX_WORK_ROOT=D:\cfix_sandbox
SANDBOX_MEMORY=256m
SANDBOX_CPUS=0.5
SANDBOX_PIDS_LIMIT=64
SANDBOX_READ_ONLY=true
SANDBOX_DOCKER_BIN=docker
SANDBOX_KEEP_TEMP=false
